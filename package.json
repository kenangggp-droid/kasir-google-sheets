{
  "name": "kasir-google-sheets",
  "private": true,
  "version": "1.0.4",
  "description": "Website kasir React + Vite + Tailwind dengan Google Sheets dan Google Apps Script REST API.",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "pnpm run build && wrangler dev",
    "release:check": "vite build",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "wrangler": "^4.106.0"
  }
}
